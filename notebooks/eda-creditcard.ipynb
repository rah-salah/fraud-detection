 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["# EDA - Credit Card Data\n", "Exploratory Data Analysis for creditcard.csv"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "%matplotlib inline\n",
    "sns.set_style('whitegrid')\n",
    "print('Libraries loaded!')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load data\n",
    "df = pd.read_csv('../data/raw/creditcard.csv')\n",
    "print(f'Shape: {df.shape}')\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Basic info\n",
    "print('=== Data Types ===')\n",
    "print(df.dtypes)\n",
    "print('\\n=== Missing Values ===')\n",
    "print(df.isnull().sum())\n",
    "print('\\n=== Duplicates ===')\n",
    "print(f'Duplicates: {df.duplicated().sum()}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Class imbalance\n",
    "print('=== Class Distribution ===')\n",
    "print(df['Class'].value_counts())\n",
    "print(f'\\nFraud rate: {df["Class"].mean()*100:.4f}%')\n",
    "plt.figure(figsize=(6,4))\n",
    "df['Class'].value_counts().plot(kind='bar', color=['steelblue','red'])\n",
    "plt.title('Class Distribution - Fraud vs Legitimate')\n",
    "plt.xlabel('Class (0=Legitimate, 1=Fraud)')\n",
    "plt.ylabel('Count')\n",
    "plt.xticks(rotation=0)\n",
    "plt.tight_layout()\n",
    "plt.savefig('../data/processed/class_distribution_credit.png')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Amount distribution\n",
    "plt.figure(figsize=(10,4))\n",
    "plt.subplot(1,2,1)\n",
    "df['Amount'].hist(bins=50, color='steelblue')\n",
    "plt.title('Transaction Amount Distribution')\n",
    "plt.xlabel('Amount')\n",
    "plt.subplot(1,2,2)\n",
    "df.boxplot(column='Amount', by='Class')\n",
    "plt.title('Amount by Class')\n",
    "plt.suptitle('')\n",
    "plt.tight_layout()\n",
    "plt.savefig('../data/processed/amount_dist_credit.png')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Time distribution\n",
    "plt.figure(figsize=(10,4))\n",
    "plt.subplot(1,2,1)\n",
    "df['Time'].hist(bins=50, color='steelblue')\n",
    "plt.title('Time Distribution')\n",
    "plt.subplot(1,2,2)\n",
    "df.groupby(df['Time']//3600)['Class'].mean().plot(color='steelblue')\n",
    "plt.title('Fraud Rate by Hour')\n",
    "plt.tight_layout()\n",
    "plt.savefig('../data/processed/time_dist_credit.png')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Correlation heatmap of V features\n",
    "v_cols = [f'V{i}' for i in range(1,11)]\n",
    "plt.figure(figsize=(10,8))\n",
    "sns.heatmap(df[v_cols].corr(), annot=True, fmt='.2f', cmap='coolwarm')\n",
    "plt.title('Correlation Heatmap - V1 to V10')\n",
    "plt.tight_layout()\n",
    "plt.savefig('../data/processed/correlation_heatmap_credit.png')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print('=== EDA Complete! ===')\n",
    "print(f'Total transactions: {len(df):,}')\n",
    "print(f'Fraud cases: {df["Class"].sum():,}')\n",
    "print(f'Fraud rate: {df["Class"].mean()*100:.4f}%')\n",
    "print(f'Features: {df.shape[1]}')"
   ]
  }
 ],
