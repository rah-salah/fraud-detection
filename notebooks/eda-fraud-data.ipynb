{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["# EDA - Fraud Data\n", "Exploratory Data Analysis for Fraud_Data.csv"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "%matplotlib inline\n",
    "sns.set_style('whitegrid')\n",
    "print('Libraries loaded!')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load data\n",
    "df = pd.read_csv('../data/raw/Fraud_Data.csv')\n",
    "print(f'Shape: {df.shape}')\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Basic info\n",
    "print('=== Data Types ===')\n",
    "print(df.dtypes)\n",
    "print('\\n=== Missing Values ===')\n",
    "print(df.isnull().sum())\n",
    "print('\\n=== Duplicates ===')\n",
    "print(f'Duplicates: {df.duplicated().sum()}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Class imbalance\n",
    "print('=== Class Distribution ===')\n",
    "print(df['class'].value_counts())\n",
    "print(f'\\nFraud rate: {df["class"].mean()*100:.2f}%')\n",
    "plt.figure(figsize=(6,4))\n",
    "df['class'].value_counts().plot(kind='bar', color=['steelblue','red'])\n",
    "plt.title('Class Distribution - Fraud vs Legitimate')\n",
    "plt.xlabel('Class (0=Legitimate, 1=Fraud)')\n",
    "plt.ylabel('Count')\n",
    "plt.xticks(rotation=0)\n",
    "plt.tight_layout()\n",
    "plt.savefig('../data/processed/class_distribution_fraud.png')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Purchase value distribution\n",
    "plt.figure(figsize=(10,4))\n",
    "plt.subplot(1,2,1)\n",
    "df['purchase_value'].hist(bins=50, color='steelblue')\n",
    "plt.title('Purchase Value Distribution')\n",
    "plt.xlabel('Purchase Value')\n",
    "plt.subplot(1,2,2)\n",
    "df.boxplot(column='purchase_value', by='class')\n",
    "plt.title('Purchase Value by Class')\n",
    "plt.suptitle('')\n",
    "plt.tight_layout()\n",
    "plt.savefig('../data/processed/purchase_value_dist.png')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Age distribution\n",
    "plt.figure(figsize=(10,4))\n",
    "plt.subplot(1,2,1)\n",
    "df['age'].hist(bins=30, color='steelblue')\n",
    "plt.title('Age Distribution')\n",
    "plt.subplot(1,2,2)\n",
    "df.boxplot(column='age', by='class')\n",
    "plt.title('Age by Class')\n",
    "plt.suptitle('')\n",
    "plt.tight_layout()\n",
    "plt.savefig('../data/processed/age_dist.png')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Categorical features\n",
    "fig, axes = plt.subplots(1,3, figsize=(15,4))\n",
    "for idx, col in enumerate(['source', 'browser', 'sex']):\n",
    "    df.groupby(col)['class'].mean().sort_values().plot(\n",
    "        kind='bar', ax=axes[idx], color='steelblue'\n",
    "    )\n",
    "    axes[idx].set_title(f'Fraud Rate by {col}')\n",
    "    axes[idx].set_ylabel('Fraud Rate')\n",
    "    axes[idx].tick_params(rotation=45)\n",
    "plt.tight_layout()\n",
    "plt.savefig('../data/processed/categorical_fraud_rate.png')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Time analysis\n",
    "df['signup_time'] = pd.to_datetime(df['signup_time'])\n",
    "df['purchase_time'] = pd.to_datetime(df['purchase_time'])\n",
    "df['hour_of_day'] = df['purchase_time'].dt.hour\n",
    "df['day_of_week'] = df['purchase_time'].dt.dayofweek\n",
    "df['time_since_signup'] = (df['purchase_time'] - df['signup_time']).dt.total_seconds()/3600\n",
    "fig, axes = plt.subplots(1,3, figsize=(15,4))\n",
    "df.groupby('hour_of_day')['class'].mean().plot(ax=axes[0], color='steelblue')\n",
    "axes[0].set_title('Fraud Rate by Hour of Day')\n",
    "df.groupby('day_of_week')['class'].mean().plot(ax=axes[1], color='steelblue')\n",
    "axes[1].set_title('Fraud Rate by Day of Week')\n",
    "df['time_since_signup'].hist(bins=50, ax=axes[2], color='steelblue')\n",
    "axes[2].set_title('Time Since Signup Distribution')\n",
    "plt.tight_layout()\n",
    "plt.savefig('../data/processed/time_analysis.png')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print('=== EDA Complete! ===')\n",
    "print(f'Total transactions: {len(df):,}')\n",
    "print(f'Fraud cases: {df["class"].sum():,}')\n",
    "print(f'Fraud rate: {df["class"].mean()*100:.2f}%')\n",
    "print(f'Features: {df.shape[1]}')"
   ]
  }
 ],
